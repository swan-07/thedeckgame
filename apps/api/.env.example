# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
# New-style secret key (sb_secret_...). ⚠️ backend only, never ship to client.
# Settings → API Keys → Secret keys.
SUPABASE_SECRET_KEY=sb_secret_xxx
# Leave empty when your project uses JWT signing keys (the default). Only set
# this if your project still signs tokens with the legacy HS256 shared secret.
SUPABASE_JWT_SECRET=

# ── Database ───────────────────────────────────────────────────────────────
# App runtime uses the transaction pooler (port 6543).
DATABASE_URL=postgresql+psycopg://postgres.your-ref:PASSWORD@aws-region.pooler.supabase.com:6543/postgres
# Alembic migrations use the direct connection (port 5432).
DATABASE_DIRECT_URL=postgresql+psycopg://postgres.your-ref:PASSWORD@aws-region.pooler.supabase.com:5432/postgres

# ── App config ─────────────────────────────────────────────────────────────
ADMIN_EMAILS=you@gmail.com        # comma-separated allowlist; these accounts get role=admin
RESUMES_BUCKET=resumes
CORS_ORIGINS=http://localhost:5173
